// ── GIF encoder ──
const GIFEncoder=(()=>{
  function NeuQuant(pixels,samplefac){
    const N=256,intbias=1<<16,alphabiasshift=10,initalpha=1<<alphabiasshift;
    const radbiasshift=8,radbias=1<<radbiasshift,alpharadbias=1<<(alphabiasshift+radbiasshift);
    const radiusdec=30;
    let net=[],freq=new Array(N).fill(intbias/N),bias=new Array(N).fill(0),radpower=[];
    for(let i=0;i<N;i++)net[i]=[i*256/N,i*256/N,i*256/N];
    function contest(b,g,r){let bd=1<<28,bbd=bd,bp=0,bbp=0;for(let i=0;i<N;i++){const n=net[i],d=Math.abs(n[0]-b)+Math.abs(n[1]-g)+Math.abs(n[2]-r);if(d<bd){bd=d;bp=i;}const biasd=d-(bias[i]>>(16-4));if(biasd<bbd){bbd=biasd;bbp=i;}freq[i]-=freq[i]>>3;bias[i]+=freq[i]<<4;}freq[bp]+=intbias/N|0;bias[bp]-=intbias<<(10-10);return bbp;}
    function alter(alpha,i,b,g,r){net[i][0]-=alpha*(net[i][0]-b)/initalpha;net[i][1]-=alpha*(net[i][1]-g)/initalpha;net[i][2]-=alpha*(net[i][2]-r)/initalpha;}
    function alterneigh(rad,i,b,g,r){const lo=Math.max(i-rad,0),hi=Math.min(i+rad,N);for(let j=i+1,k=i-1,m=1;j<hi||k>lo;m++){const a=radpower[m]||0;if(j<hi){net[j][0]-=a*(net[j][0]-b)/alpharadbias;net[j][1]-=a*(net[j][1]-g)/alpharadbias;net[j][2]-=a*(net[j][2]-r)/alpharadbias;j++;}if(k>lo){net[k][0]-=a*(net[k][0]-b)/alpharadbias;net[k][1]-=a*(net[k][1]-g)/alpharadbias;net[k][2]-=a*(net[k][2]-r)/alpharadbias;k--;}}}
    const len=pixels.length,sp=len/(4*samplefac)|0;
    let delta=Math.max(sp/100|0,1),alpha=initalpha,radius=N*4;
    let rad=radius>>6;if(rad<=1)rad=0;
    for(let i=0;i<rad;i++)radpower[i]=alpha*(((rad*rad-i*i)*radbias)/(rad*rad))|0;
    const step=len<8192?4:(len%4831?4*4831:(len%4649?4*4649:4*4783));
    for(let i=0,pix=0;i<sp;i++){const b=pixels[pix+2]&255,g=pixels[pix+1]&255,r=pixels[pix]&255;const j=contest(b,g,r);alter(alpha,j,b,g,r);if(rad)alterneigh(rad,j,b,g,r);pix+=step;if(pix>=len)pix-=len;if(i%delta===0){alpha-=alpha/(30+(samplefac-1)/3|0);radius-=radius/radiusdec;rad=radius>>6;if(rad<=1)rad=0;for(let jj=0;jj<rad;jj++)radpower[jj]=alpha*(((rad*rad-jj*jj)*radbias)/(rad*rad))|0;}}
    const sorted=[...Array(N).keys()].sort((a,b)=>net[a][1]-net[b][1]);
    const palette=new Uint8Array(N*3);
    sorted.forEach((netIdx,palIdx)=>{palette[palIdx*3+0]=net[netIdx][2]|0;palette[palIdx*3+1]=net[netIdx][1]|0;palette[palIdx*3+2]=net[netIdx][0]|0;});
    function map(r,g,b){let best=0,bestd=1e9;for(let i=0;i<N;i++){const dr=palette[i*3]-r,dg=palette[i*3+1]-g,db=palette[i*3+2]-b,d=dr*dr+dg*dg+db*db;if(d<bestd){bestd=d;best=i;}}return best;}
    return{palette,map};
  }
  function lzwEncode(indices,minCS){
    const clear=1<<minCS,eoi=clear+1;let codeSize=minCS+1,maxCode=1<<codeSize;
    const out=[];let buf=0,bufBits=0;
    function emit(code){buf|=code<<bufBits;bufBits+=codeSize;while(bufBits>=8){out.push(buf&0xff);buf>>>=8;bufBits-=8;}}
    let table={};let nextCode=eoi+1;
    function reset(){table={};for(let i=0;i<clear;i++)table[String(i)]=i;emit(clear);codeSize=minCS+1;maxCode=1<<codeSize;nextCode=eoi+1;}
    reset();let seq=String(indices[0]);
    for(let i=1;i<indices.length;i++){const c=indices[i];const ext=seq+','+c;if(table[ext]!==undefined){seq=ext;}else{emit(table[seq]);if(nextCode<4096){table[ext]=nextCode++;if(nextCode>maxCode&&codeSize<12){codeSize++;maxCode<<=1;}}else{emit(clear);table={};for(let j=0;j<clear;j++)table[String(j)]=j;nextCode=eoi+1;codeSize=minCS+1;maxCode=1<<codeSize;}seq=String(c);}}
    emit(table[seq]);emit(eoi);if(bufBits>0)out.push(buf&0xff);return out;
  }
  function writeSubBlocks(arr,bytes){for(let i=0;i<bytes.length;){const n=Math.min(255,bytes.length-i);arr.push(n);for(let j=0;j<n;j++)arr.push(bytes[i++]);}arr.push(0);}
  function encode(frames,w,h){
    const out=[];const u16=v=>{out.push(v&0xff,(v>>8)&0xff);};const str=s=>{for(let i=0;i<s.length;i++)out.push(s.charCodeAt(i)&0xff);};
    const sampleFrames=[frames[0],frames[Math.floor(frames.length/3)],frames[Math.floor(frames.length*2/3)],frames[frames.length-1]];
    const merged=new Uint8Array(sampleFrames.reduce((s,f)=>s+f.pixels.length,0));
    let moff=0;sampleFrames.forEach(f=>{merged.set(f.pixels,moff);moff+=f.pixels.length;});
    const nq=NeuQuant(merged,10);const pal=nq.palette;
    str('GIF89a');u16(w);u16(h);out.push(0xf7,0,0);for(let i=0;i<768;i++)out.push(pal[i]);
    out.push(0x21,0xff,0x0b);str('NETSCAPE2.0');out.push(0x03,0x01,0x00,0x00,0x00);
    for(const frame of frames){const delay=Math.max(5,Math.round(frame.delay/10));out.push(0x21,0xf9,0x04,0x00);u16(delay);out.push(0,0);out.push(0x2c);u16(0);u16(0);u16(w);u16(h);out.push(0);const px=frame.pixels,idx=new Uint8Array(w*h);for(let i=0;i<w*h;i++){const j=i*4;idx[i]=nq.map(px[j],px[j+1],px[j+2]);}out.push(8);writeSubBlocks(out,lzwEncode(idx,8));}
    out.push(0x3b);return new Uint8Array(out);
  }
  return{encode};
})();

// ── Export ──
function getQualitySize(){return{low:240,med:480,high:720,ultra:1080}[document.getElementById('eQuality').value]||480;}

function exportPNG(){
  const sz=getQualitySize();
  const off=document.createElement('canvas');off.width=off.height=sz;
