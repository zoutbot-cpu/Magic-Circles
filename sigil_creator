<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sigil Creator</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#000;color:#ccc;font-family:sans-serif;height:100vh;display:flex;flex-direction:column;overflow:hidden}

/* toolbar */
#toolbar{display:flex;flex-wrap:wrap;gap:6px;padding:8px 10px;background:#0c0c0c;border-bottom:1px solid #1e1e1e;flex-shrink:0}
.ctrl{display:flex;flex-direction:column;gap:2px;min-width:0}
.ctrl label{font-size:10px;color:#555;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap}
.ctrl select,.ctrl input[type=text]{font-size:12px;background:#111;color:#ccc;border:1px solid #2a2a2a;border-radius:3px;padding:3px 6px;width:100%}
.ctrl input[type=range]{width:100%}
.val{font-size:11px;color:#aaa;text-align:center}
.btn-row{display:flex;gap:5px;align-items:flex-end;flex-wrap:wrap}
button{font-size:11px;padding:4px 10px;cursor:pointer;background:#111;color:#aaa;border:1px solid #2a2a2a;border-radius:3px;white-space:nowrap}
button:hover{background:#1c1c1c;color:#fff;border-color:#444}
button.on{background:#1a1a1a;color:#fff;border-color:#555}

/* main */
#main{display:flex;flex:1;overflow:hidden;min-height:0}

/* left panel */
#lpanel{width:220px;background:#080808;border-right:1px solid #181818;padding:10px;display:flex;flex-direction:column;gap:10px;overflow-y:auto;overflow-x:hidden;flex-shrink:0}
#lpanel *{max-width:100%;box-sizing:border-box}
#lpanel input[type=range]{width:100%;min-width:0}
#lpanel select{width:100%;min-width:0}
.ph3{font-size:10px;color:#444;text-transform:uppercase;letter-spacing:1px;margin-bottom:3px}
.layer{display:flex;align-items:center;gap:6px;font-size:11px;color:#777;padding:3px 0;border-bottom:1px solid #0e0e0e}
.layer span{flex:1}
.srow{display:flex;align-items:center;gap:6px;margin-bottom:5px}
.srow label{font-size:11px;color:#666;width:72px;flex-shrink:0;white-space:nowrap}
.srow input[type=range]{flex:1;min-width:0}
.srow .sv{font-size:11px;color:#aaa;width:28px;text-align:right;flex-shrink:0}

/* canvas */
#canvasWrap{flex:1;display:flex;align-items:center;justify-content:center;background:#000;overflow:hidden}
canvas{display:block;max-width:100%;max-height:100%}

/* right panel */
#rpanel{width:190px;background:#080808;border-left:1px solid #181818;padding:10px;display:flex;flex-direction:column;gap:8px;overflow-y:auto;overflow-x:hidden;flex-shrink:0}
#rpanel *{max-width:100%;box-sizing:border-box}

/* letter display */
#letterDisplay{background:#111;border:1px solid #222;border-radius:4px;padding:8px;min-height:36px;font-size:16px;letter-spacing:3px;color:#FFD700;text-shadow:0 0 8px #AA6600;word-break:break-all;line-height:1.6}
#intentionDisplay{font-size:10px;color:#555;margin-top:4px;word-break:break-all}

/* colour swatches */
.sw-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:3px}
.sw{width:100%;aspect-ratio:1;border-radius:2px;cursor:pointer;border:2px solid transparent}
.sw:hover{opacity:.8}
.sw.sel{border-color:#fff}

/* grid preview strip */
#gridPreview{display:flex;gap:5px;flex-wrap:wrap;margin-top:4px}
.gp{font-size:9px;color:#555;text-align:center;cursor:pointer;padding:3px 5px;border:1px solid #1a1a1a;border-radius:3px;background:#0d0d0d}
.gp.sel{border-color:#444;color:#aaa;background:#151515}

/* step list */
#stepList{font-size:11px;color:#666;line-height:1.8;max-height:160px;overflow-y:auto}
#stepList span{color:#FFD700}

/* history */
.hist-item{font-size:11px;padding:4px 6px;background:#0d0d0d;border:1px solid #181818;border-radius:3px;cursor:pointer;margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#888}
.hist-item:hover{background:#151515;color:#ccc}

::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:#080808}::-webkit-scrollbar-thumb{background:#222;border-radius:2px}
</style>
</head>
<body>

<div id="toolbar">
  <div class="ctrl" style="min-width:200px">
    <label>Intention / word</label>
    <input type="text" id="tIntention" placeholder="e.g. PROTECTION or I AM CREATIVE" value="PROTECTION">
  </div>
  <div class="ctrl" style="min-width:100px">
    <label>Reduction</label>
    <select id="tReduction">
      <option value="dupes">Remove duplicates</option>
      <option value="dupvow">Remove dupes + vowels</option>
      <option value="none">Keep all letters</option>
    </select>
  </div>
  <div class="ctrl" style="min-width:90px">
    <label>Grid type</label>
    <select id="tGrid">
      <option value="rosecross">Rose Cross</option>
      <option value="wheel">Number wheel</option>
      <option value="circle">Letter circle</option>
      <option value="chaos">Chaos scatter</option>
      <option value="grid5">5×5 square</option>
    </select>
  </div>
  <div class="ctrl" style="min-width:80px">
    <label>Line style</label>
    <select id="tLineStyle">
      <option value="angular">Angular</option>
      <option value="bezier">Bezier curves</option>
      <option value="arc">Arc curves</option>
    </select>
  </div>
  <div class="ctrl" style="min-width:75px">
    <label>Terminals</label>
    <select id="tTerminal">
      <option value="none">None</option>
      <option value="dot" selected>Dot</option>
      <option value="circle">Circle</option>
      <option value="diamond">Diamond</option>
      <option value="cross">Cross</option>
    </select>
  </div>
  <div class="ctrl" style="width:58px">
    <label>Line</label>
    <input type="range" id="tLW" min="2" max="30" value="14" step="1">
    <span class="val" id="vLW">1.4</span>
  </div>
  <div class="ctrl" style="width:58px">
    <label>Glow</label>
    <input type="range" id="tGlow" min="0" max="50" value="18" step="1">
    <span class="val" id="vGlow">18</span>
  </div>
  <div class="ctrl" style="width:58px">
    <label>Smooth</label>
    <input type="range" id="tSmooth" min="0" max="100" value="40" step="1">
    <span class="val" id="vSmooth">40%</span>
  </div>
  <div class="ctrl" style="width:58px">
    <label>Grid scale</label>
    <input type="range" id="tGScale" min="30" max="110" value="75" step="1">
    <span class="val" id="vGScale">75%</span>
  </div>
  <div class="ctrl" style="width:58px">
    <label>Rotate</label>
    <input type="range" id="tRot" min="0" max="360" value="0" step="1">
    <span class="val" id="vRot">0°</span>
  </div>
  <div class="ctrl" style="width:58px">
    <label>Chaos seed</label>
    <input type="range" id="tSeed" min="1" max="999" value="42" step="1">
    <span class="val" id="vSeed">42</span>
  </div>
  <div class="btn-row">
    <button id="bGenerate">Generate ✦</button>
    <button id="bAnimate">Trace ▶</button>
    <button id="bRandom">Random 🎲</button>
    <button id="bOverlay" id="bOverlay">Circle overlay</button>
    <button id="bPNG">Save PNG</button>
    <button id="bGIF">Save GIF</button>
    <span id="status" style="font-size:11px;color:#666;align-self:center"></span>
  </div>
</div>

<div id="main">
  <!-- LEFT PANEL -->
  <div id="lpanel">
    <div>
      <div class="ph3">Processed letters</div>
      <div id="letterDisplay">—</div>
      <div id="intentionDisplay"></div>
    </div>

    <div>
      <div class="ph3">Colour</div>
      <div class="sw-grid" id="swColor"></div>
      <div style="margin-top:5px">
        <input type="color" id="customColor" value="#FFD700" style="width:100%;height:26px;background:#111;border:1px solid #2a2a2a;border-radius:3px;cursor:pointer">
      </div>
    </div>

    <div>
      <div class="ph3">Background</div>
      <div class="sw-grid" id="swBg"></div>
      <input type="color" id="customBg" value="#000000" style="width:100%;height:24px;margin-top:4px;background:#111;border:1px solid #2a2a2a;border-radius:3px;cursor:pointer">
    </div>

    <div>
      <div class="ph3">Outer circle</div>
      <div class="layer"><input type="checkbox" id="lCircle" checked><span>Draw outer ring</span></div>
      <div class="layer"><input type="checkbox" id="lGrid" checked><span>Show grid/nodes</span></div>
      <div class="layer"><input type="checkbox" id="lLabels" checked><span>Letter labels</span></div>
      <div class="layer"><input type="checkbox" id="lDoubleRing"><span>Double ring</span></div>
      <div class="layer"><input type="checkbox" id="lTicks" checked><span>Tick marks</span></div>
      <div class="layer"><input type="checkbox" id="lShadow" checked><span>Drop shadow</span></div>
      <div class="srow" style="margin-top:6px">
        <label>Opacity</label>
        <input type="range" id="tOpacity" min="10" max="100" value="100">
        <span class="sv" id="vOpacity">100%</span>
      </div>
      <div class="srow">
        <label>Sigil weight</label>
        <input type="range" id="tSigilW" min="50" max="200" value="100">
        <span class="sv" id="vSigilW">100%</span>
      </div>
    </div>

    <div>
      <div class="ph3">Circle overlay style</div>
      <select id="tOverlayStyle" style="width:100%;font-size:12px;background:#111;color:#ccc;border:1px solid #2a2a2a;border-radius:3px;padding:3px 5px;margin-bottom:5px">
        <option value="star">Star polygon</option>
        <option value="orbital">Orbital</option>
        <option value="alchemic">Alchemic</option>
        <option value="pentagram">Pentagram</option>
        <option value="mandala">Mandala</option>
        <option value="celtic">Celtic knot</option>
        <option value="rose">Rose window</option>
        <option value="norse">Norse web</option>
        <option value="chaos_s">Chaos star</option>
      </select>
      <div class="srow">
        <label>Overlay opacity</label>
        <input type="range" id="tOverlayOp" min="5" max="80" value="25">
        <span class="sv" id="vOverlayOp">25%</span>
      </div>
    </div>

    <div>
      <div class="ph3">Export quality</div>
      <select id="eQuality" style="width:100%;font-size:12px;background:#111;color:#ccc;border:1px solid #2a2a2a;border-radius:3px;padding:3px 5px;margin-bottom:4px">
        <option value="low">Low 240px</option>
        <option value="med" selected>Med 480px</option>
        <option value="high">High 720px</option>
        <option value="ultra">Ultra 1080px</option>
      </select>
      <select id="eFrames" style="width:100%;font-size:12px;background:#111;color:#ccc;border:1px solid #2a2a2a;border-radius:3px;padding:3px 5px">
        <option value="40">40 frames (2s)</option>
        <option value="60" selected>60 frames (3s)</option>
        <option value="80">80 frames (4s)</option>
      </select>
    </div>
  </div>

  <!-- CANVAS -->
  <div id="canvasWrap">
    <canvas id="c" width="600" height="600"></canvas>
  </div>

  <!-- RIGHT PANEL -->
  <div id="rpanel">
    <div>
      <div class="ph3">Letter path</div>
      <div id="stepList">Enter an intention above and click Generate.</div>
    </div>
    <div>
      <div class="ph3">History</div>
      <div id="histList"></div>
    </div>
    <div>
      <div class="ph3">Interpretation</div>
      <div id="interpBox" style="font-size:11px;color:#555;line-height:1.7"></div>
    </div>
  </div>
</div>

<script>
// ── Colour palettes ──
const COLS={gold:'#FFD700',silver:'#D0D0D0',cyan:'#00FFFF',rose:'#FF69B4',emerald:'#00FF88',purple:'#BB88FF',crimson:'#FF3333',azure:'#4488FF',amber:'#FFAA00',white:'#FFFFFF',teal:'#00CCBB',lime:'#AAFF00'};
const GLOWS={gold:'#AA6600',silver:'#808080',cyan:'#006688',rose:'#880044',emerald:'#006622',purple:'#440088',crimson:'#660000',azure:'#001188',amber:'#884400',white:'#888888',teal:'#005544',lime:'#448800'};
const BGS={'#000000':'Black','#070010':'Deep void','#000820':'Night sea','#100008':'Blood dark','#081000':'Forest','#0d0900':'Parchment','#1a1a2e':'Midnight'};

// ── Canvas ──
const CV=document.getElementById('c');
const ctx=CV.getContext('2d',{willReadFrequently:true});
const W=()=>CV.width,H=()=>CV.height,CX=()=>W()/2,CY=()=>H()/2;
function resize(){
  const wrap=document.getElementById('canvasWrap');
  const sz=Math.min(wrap.clientWidth,wrap.clientHeight)-16;
  CV.width=CV.height=Math.max(sz,300);
  render();
}
window.addEventListener('resize',resize);

// ── State ──
let S={
  intention:'PROTECTION',
  reduction:'dupes',
  grid:'rosecross',
  lineStyle:'angular',
  terminal:'dot',
  lw:1.4,glow:18,smooth:0.4,gscale:0.75,rotate:0,seed:42,
  color:'#FFD700',glow2:'#AA6600',bg:'#000000',
  opacity:1,sigilWeight:1,
  layers:{circle:true,grid:true,labels:true,doubleRing:false,ticks:true,shadow:true},
  overlay:false,overlayStyle:'star',overlayOp:0.25,
  letters:[],points:[],
};
let animating=false,animId=null,animProgress=0;
let history=[];

// ── Letter reduction ──
const VOWELS=new Set('AEIOU');
function processIntention(text,mode){
  const upper=text.toUpperCase().replace(/[^A-Z]/g,'');
  let letters=[];
  const seen=new Set();
  for(const ch of upper){
    if(mode==='dupes'&&seen.has(ch))continue;
    if(mode==='dupvow'&&(seen.has(ch)||VOWELS.has(ch)))continue;
    seen.add(ch);
    letters.push(ch);
  }
  if(mode==='none'){letters=[...upper];}
  return letters;
}

// ── Grid layouts ──
// Rose Cross: classic 5-row grid where each letter maps to a cell
// Layout: A=1,B=2,C=3, D=4,E=5,F=6, G=7,H=8,I=9, IJ share, K=10... etc
const ROSE_CROSS_POS={
  // row,col in a 4x6 grid (0-indexed)
  A:[0,0],B:[0,1],C:[0,2],
  D:[1,0],E:[1,1],F:[1,2],
  G:[2,0],H:[2,1],I:[2,2],J:[2,2],
  K:[3,0],L:[3,1],M:[3,2],
  N:[4,0],O:[4,1],P:[4,2],
  Q:[5,0],R:[5,1],S:[5,2],
  T:[6,0],U:[6,1],V:[6,2],
  W:[7,0],X:[7,1],Y:[7,2],Z:[7,1]
};

// Seeded RNG for chaos grid
function seededRand(seed){
  let s=seed;
  return function(){s=(s*1664525+1013904223)&0xffffffff;return (s>>>0)/0xffffffff;};
}

function getGridPoints(gridType,letters,R,cx,cy,seed,rotate){
  const TAU=Math.PI*2;
  const pts={};
  const rand=seededRand(seed);

  if(gridType==='circle'){
    // Letters equally spaced around a circle
    const alpha='ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    for(let i=0;i<26;i++){
      const a=rotate+(i/26)*TAU - TAU/4;
      pts[alpha[i]]={x:cx+R*Math.cos(a),y:cy+R*Math.sin(a),label:alpha[i]};
    }
  }
  else if(gridType==='wheel'){
    // Number wheel: 9 positions, letters map to numerology value
    const num={A:1,B:2,C:3,D:4,E:5,F:6,G:7,H:8,I:9,J:1,K:2,L:3,M:4,N:5,O:6,P:7,Q:8,R:9,S:1,T:2,U:3,V:4,W:5,X:6,Y:7,Z:8};
    for(let n=1;n<=9;n++){
      const a=rotate+((n-1)/9)*TAU - TAU/4;
      const lbl=Object.entries(num).filter(([,v])=>v===n).map(([k])=>k).join('');
      pts['_n'+n]={x:cx+R*Math.cos(a),y:cy+R*Math.sin(a),label:lbl,num:n};
    }
    // Map each letter to its wheel position
    const letterMap={};
    for(const ch of 'ABCDEFGHIJKLMNOPQRSTUVWXYZ') letterMap[ch]=pts['_n'+num[ch]];
    return{pts,letterMap,type:'wheel'};
  }
  else if(gridType==='rosecross'){
    // Rose Cross grid: 3 columns, 8 rows
    const cellW=R*0.55,cellH=R*0.28;
    const startX=cx-cellW;const startY=cy-cellH*3.5;
    const alpha='ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    for(let i=0;i<alpha.length;i++){
      const row=Math.floor(i/3),col=i%3;
      let x=startX+col*cellW+cellW/2;
      let y=startY+row*cellH+cellH/2;
      // Rotate around center
      const dx=x-cx,dy=y-cy;
      const cos=Math.cos(rotate),sin=Math.sin(rotate);
      x=cx+dx*cos-dy*sin;y=cy+dx*sin+dy*cos;
      pts[alpha[i]]={x,y,label:alpha[i]};
    }
  }
  else if(gridType==='grid5'){
    // Classic 5x5 magic square layout (Polybius style)
    const alpha='ABCDEFGHIKLMNOPQRSTUVWXYZ'; // I=J
    const step=R*0.44;
    const startX=cx-step*2;const startY=cy-step*2;
    for(let i=0;i<25;i++){
      const row=Math.floor(i/5),col=i%5;
      let x=startX+col*step,y=startY+row*step;
      const dx=x-cx,dy=y-cy;
      const cos=Math.cos(rotate),sin=Math.sin(rotate);
      x=cx+dx*cos-dy*sin;y=cy+dx*sin+dy*cos;
      pts[alpha[i]]={x,y,label:alpha[i]};
      if(alpha[i]==='I')pts['J']={x,y,label:'I/J'};
    }
  }
  else if(gridType==='chaos'){
    // Random scatter with seed, letters placed on pseudo-random positions
    const alpha='ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    // Use Halton-like low-discrepancy with seed offset for even-ish spread
    for(let i=0;i<26;i++){
      const angle=rand()*TAU;
      const radius=R*(0.25+rand()*0.7);
      let x=cx+radius*Math.cos(angle),y=cy+radius*Math.sin(angle);
      pts[alpha[i]]={x,y,label:alpha[i]};
    }
  }
  return{pts,type:gridType};
}

function getLetterPoint(ch,gridData){
  if(gridData.type==='wheel') return gridData.letterMap[ch]||null;
  return gridData.pts[ch]||null;
}

// ── Drawing ──
function getCol(alpha=1){
  const h=S.color;const r=parseInt(h.slice(1,3),16),g=parseInt(h.slice(3,5),16),b=parseInt(h.slice(5,7),16);
  return `rgba(${r},${g},${b},${alpha*S.opacity})`;
}

function drawGrid(gridData,R,showLabels){
  const L=S.layers;
  ctx.save();
  ctx.shadowBlur=S.glow*0.4;ctx.shadowColor=S.glow2;

  if(S.grid==='circle'||S.grid==='wheel'){
    if(L.circle){
      ctx.strokeStyle=getCol(0.3);ctx.lineWidth=S.lw*0.5;
      ctx.beginPath();ctx.arc(CX(),CY(),R,0,Math.PI*2);ctx.stroke();
      if(L.doubleRing){ctx.lineWidth=S.lw*0.25;ctx.beginPath();ctx.arc(CX(),CY(),R*1.04,0,Math.PI*2);ctx.stroke();}
    }
    if(L.ticks){
      ctx.strokeStyle=getCol(0.2);ctx.lineWidth=S.lw*0.3;
      const n=S.grid==='circle'?26:9;
      for(let i=0;i<n;i++){
        const a=(i/n)*Math.PI*2+S.rotate-Math.PI/2;
        ctx.beginPath();ctx.moveTo(CX()+(R-8)*Math.cos(a),CY()+(R-8)*Math.sin(a));
        ctx.lineTo(CX()+(R+8)*Math.cos(a),CY()+(R+8)*Math.sin(a));ctx.stroke();
      }
    }
  } else if(S.grid==='rosecross'){
    if(L.circle){
      // draw the cross lines
      ctx.strokeStyle=getCol(0.15);ctx.lineWidth=S.lw*0.4;
      const cos=Math.cos(S.rotate),sin=Math.sin(S.rotate);
      // vertical
      ctx.beginPath();
      ctx.moveTo(CX()-sin*R*0.85,CY()+cos*R*0.85);
      ctx.lineTo(CX()+sin*R*0.85,CY()-cos*R*0.85);ctx.stroke();
      // horizontal
      ctx.beginPath();
      ctx.moveTo(CX()-cos*R*0.7,CY()-sin*R*0.7);
      ctx.lineTo(CX()+cos*R*0.7,CY()+sin*R*0.7);ctx.stroke();
      // outer ellipse hint
      ctx.beginPath();ctx.ellipse(CX(),CY(),R*0.7,R*1.1,S.rotate,0,Math.PI*2);ctx.stroke();
    }
  } else if(S.grid==='grid5'){
    if(L.circle){
      // draw grid lines
      ctx.strokeStyle=getCol(0.12);ctx.lineWidth=S.lw*0.35;
      const step=R*0.44,cos=Math.cos(S.rotate),sin=Math.sin(S.rotate);
      for(let i=-2;i<=2;i++){
        // horizontal
        const y1=CY()+i*step*cos-2*step*sin,x1=CX()+i*step*sin+(-2)*step*cos;
        const y2=CY()+i*step*cos+2*step*sin,x2=CX()+i*step*sin+2*step*cos;
        ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke();
        // vertical
        const vy1=CY()+(-2)*step*cos-i*step*sin,vx1=CX()+(-2)*step*sin+i*step*cos;
        const vy2=CY()+2*step*cos-i*step*sin,vx2=CX()+2*step*sin+i*step*cos;
        ctx.beginPath();ctx.moveTo(vx1,vy1);ctx.lineTo(vx2,vy2);ctx.stroke();
      }
    }
  }

  // Draw node dots and labels
  if(L.grid){
    Object.values(gridData.pts).filter(p=>!p.label?.startsWith?.('_')).forEach(p=>{
      ctx.fillStyle=getCol(0.2);ctx.shadowBlur=0;
      ctx.beginPath();ctx.arc(p.x,p.y,2.5,0,Math.PI*2);ctx.fill();
    });
  }
  if(showLabels&&L.labels){
    ctx.font=`${Math.max(9,Math.floor(R*0.055))}px sans-serif`;
    ctx.fillStyle=getCol(0.45);ctx.textAlign='center';ctx.textBaseline='middle';
    Object.values(gridData.pts).forEach(p=>{
      if(p.label&&!p.label.startsWith('_')){
        // offset label slightly outward from center
        const dx=p.x-CX(),dy=p.y-CY();
        const len=Math.max(1,Math.hypot(dx,dy));
        const offs=10;
        ctx.fillText(p.label,p.x+dx/len*offs,p.y+dy/len*offs);
      }
    });
  }
  ctx.restore();
}

function drawSigilPath(pts,progress=1,shadow=true){
  if(pts.length<2)return;
  ctx.save();
  if(shadow&&S.layers.shadow){ctx.shadowBlur=S.glow*2;ctx.shadowColor=S.glow2;}
  ctx.strokeStyle=getCol(1);
  ctx.lineWidth=S.lw*S.sigilWeight;
  ctx.lineCap='round';ctx.lineJoin='round';

  const totalPts=Math.floor((pts.length-1)*progress)+1;
  const subPts=pts.slice(0,totalPts);
  const partialT=(pts.length-1)*progress-(totalPts-1);

  if(S.lineStyle==='angular'){
    ctx.beginPath();
    ctx.moveTo(subPts[0].x,subPts[0].y);
    for(let i=1;i<subPts.length;i++){
      if(i===subPts.length-1&&partialT>0&&partialT<1&&i===totalPts-1){
        const prev=subPts[i-1],next=pts[i]||subPts[i];
        ctx.lineTo(prev.x+(next.x-prev.x)*partialT,prev.y+(next.y-prev.y)*partialT);
      } else ctx.lineTo(subPts[i].x,subPts[i].y);
    }
    ctx.stroke();
  }
  else if(S.lineStyle==='bezier'){
    ctx.beginPath();ctx.moveTo(subPts[0].x,subPts[0].y);
    for(let i=1;i<subPts.length;i++){
      const prev=subPts[i-1],curr=subPts[i];
      const mx=(prev.x+curr.x)/2,my=(prev.y+curr.y)/2;
      const sm=S.smooth;
      const cp1x=prev.x+(mx-prev.x)*sm,cp1y=prev.y+(my-prev.y)*sm;
      const cp2x=curr.x+(mx-curr.x)*sm,cp2y=curr.y+(my-curr.y)*sm;
      ctx.bezierCurveTo(cp1x,cp1y,cp2x,cp2y,curr.x,curr.y);
    }
    ctx.stroke();
  }
  else if(S.lineStyle==='arc'){
    ctx.beginPath();ctx.moveTo(subPts[0].x,subPts[0].y);
    for(let i=1;i<subPts.length;i++){
      const prev=subPts[i-1],curr=subPts[i];
      const mx=(prev.x+curr.x)/2,my=(prev.y+curr.y)/2;
      ctx.quadraticCurveTo(CX()+(mx-CX())*S.smooth*0.5,CY()+(my-CY())*S.smooth*0.5,curr.x,curr.y);
    }
    ctx.stroke();
  }

  // Draw terminals
  if(S.terminal!=='none'&&progress>=1){
    const first=subPts[0],last=subPts[subPts.length-1];
    const tsz=S.lw*S.sigilWeight*2.5;
    [[first,'start'],[last,'end']].forEach(([p,role])=>{
      ctx.fillStyle=getCol(1);
      if(S.terminal==='dot'){ctx.beginPath();ctx.arc(p.x,p.y,tsz,0,Math.PI*2);ctx.fill();}
      else if(S.terminal==='circle'){ctx.lineWidth=S.lw*0.8;ctx.strokeStyle=getCol(1);ctx.beginPath();ctx.arc(p.x,p.y,tsz*1.4,0,Math.PI*2);ctx.stroke();}
      else if(S.terminal==='diamond'){
        ctx.beginPath();ctx.moveTo(p.x,p.y-tsz*1.5);ctx.lineTo(p.x+tsz,p.y);ctx.lineTo(p.x,p.y+tsz*1.5);ctx.lineTo(p.x-tsz,p.y);ctx.closePath();ctx.fill();
      }
      else if(S.terminal==='cross'){
        ctx.lineWidth=S.lw*0.9;ctx.strokeStyle=getCol(1);
        ctx.beginPath();ctx.moveTo(p.x-tsz,p.y);ctx.lineTo(p.x+tsz,p.y);ctx.moveTo(p.x,p.y-tsz);ctx.lineTo(p.x,p.y+tsz);ctx.stroke();
      }
    });
  }
  ctx.restore();
}

// Draw highlighted path dots (the active letters)
function drawPathDots(pts){
  pts.forEach((p,i)=>{
    ctx.save();
    ctx.shadowBlur=S.glow;ctx.shadowColor=S.glow2;
    ctx.fillStyle=getCol(i===0?1:0.55);
    ctx.beginPath();ctx.arc(p.x,p.y,S.lw*1.5,0,Math.PI*2);ctx.fill();
    ctx.restore();
  });
}

// ── Simple circle overlay (re-implemented lightweight, not full magic circle engine) ──
function drawOverlay(style,R,alpha){
  const n=S.letters.length||6;const rot=S.rotate;const TAU=Math.PI*2;
  ctx.save();ctx.globalAlpha=alpha;ctx.strokeStyle=S.color;ctx.lineWidth=S.lw*0.6;
  ctx.shadowBlur=S.glow*0.5;ctx.shadowColor=S.glow2;

  function circ(x,y,r){ctx.beginPath();ctx.arc(x,y,r,0,TAU);ctx.stroke();}
  function poly(sides,r,rot2){ctx.save();ctx.translate(CX(),CY());ctx.rotate(rot2);ctx.beginPath();for(let i=0;i<sides;i++){const a=i*TAU/sides-Math.PI/2;i?ctx.lineTo(r*Math.cos(a),r*Math.sin(a)):ctx.moveTo(r*Math.cos(a),r*Math.sin(a));}ctx.closePath();ctx.stroke();ctx.restore();}
  function starP(r,pts2,skip,rot2){const p=[];for(let i=0;i<pts2;i++)p.push([CX()+r*Math.cos(rot2+i*TAU/pts2),CY()+r*Math.sin(rot2+i*TAU/pts2)]);ctx.beginPath();for(let i=0;i<pts2;i++){const[x,y]=p[(i*skip)%pts2];i?ctx.lineTo(x,y):ctx.moveTo(x,y);}ctx.closePath();ctx.stroke();}
  function miniC(r,cnt,sr,rot2){for(let i=0;i<cnt;i++){const a=rot2+i*TAU/cnt;circ(CX()+r*Math.cos(a),CY()+r*Math.sin(a),sr);}}

  circ(CX(),CY(),R);circ(CX(),CY(),R*0.96);
  const ns=Math.max(5,n);
  if(style==='star'){starP(R*0.85,ns,Math.max(2,Math.floor(ns/2)),rot);miniC(R,ns,5,rot);}
  else if(style==='orbital'){circ(CX(),CY(),R*0.7);miniC(R*0.85,ns,R*0.06,rot);for(let i=0;i<ns;i++){const a=rot+i*TAU/ns;ctx.beginPath();ctx.moveTo(CX()+R*0.15*Math.cos(a),CY()+R*0.15*Math.sin(a));ctx.lineTo(CX()+R*0.88*Math.cos(a),CY()+R*0.88*Math.sin(a));ctx.stroke();}}
  else if(style==='alchemic'){poly(3,R*0.7,rot);poly(3,R*0.7,rot+Math.PI);poly(4,R*0.45,rot+Math.PI/4);starP(R*0.3,6,2,rot);}
  else if(style==='pentagram'){const pp=[];for(let j=0;j<5;j++)pp.push([CX()+R*0.85*Math.cos(rot-Math.PI/2+j*TAU/5),CY()+R*0.85*Math.sin(rot-Math.PI/2+j*TAU/5)]);ctx.beginPath();[0,2,4,1,3,0].forEach((k,i)=>i?ctx.lineTo(pp[k][0],pp[k][1]):ctx.moveTo(pp[k][0],pp[k][1]));ctx.stroke();circ(CX(),CY(),R*0.4);}
  else if(style==='mandala'){circ(CX(),CY(),R*0.65);for(let i=0;i<ns;i++){const a=rot+i*TAU/ns;ctx.beginPath();ctx.moveTo(CX()+R*0.05*Math.cos(a),CY()+R*0.05*Math.sin(a));ctx.lineTo(CX()+R*0.9*Math.cos(a),CY()+R*0.9*Math.sin(a));ctx.stroke();}starP(R*0.5,ns,Math.max(2,Math.floor(ns/2)),rot);}
  else if(style==='celtic'){for(let i=0;i<ns;i++){const a=rot+i*TAU/ns,b=rot+(i+2)*TAU/ns;const x1=CX()+R*0.74*Math.cos(a),y1=CY()+R*0.74*Math.sin(a),x2=CX()+R*0.74*Math.cos(b),y2=CY()+R*0.74*Math.sin(b);ctx.beginPath();ctx.moveTo(x1,y1);const mx=(x1+x2)/2+(y2-y1)*0.3,my=(y1+y2)/2-(x2-x1)*0.3;ctx.quadraticCurveTo(mx,my,x2,y2);ctx.stroke();}}
  else if(style==='rose'){for(let i=0;i<ns;i++){const a=rot+i*TAU/ns,pr=R*0.4;circ(CX()+pr*Math.cos(a),CY()+pr*Math.sin(a),pr);}}
  else if(style==='norse'){for(let i=0;i<8;i++){const a=rot+i*TAU/8;ctx.beginPath();ctx.moveTo(CX()+R*0.08*Math.cos(a),CY()+R*0.08*Math.sin(a));ctx.lineTo(CX()+R*0.82*Math.cos(a),CY()+R*0.82*Math.sin(a));ctx.stroke();}starP(R*0.4,8,3,rot);}
  else if(style==='chaos_s'){for(let i=0;i<8;i++){const a=rot+i*TAU/8;ctx.beginPath();ctx.moveTo(CX(),CY());ctx.lineTo(CX()+R*0.9*Math.cos(a),CY()+R*0.9*Math.sin(a));ctx.stroke();}circ(CX(),CY(),R*0.45);}

  ctx.restore();
}

// ── Main render ──
function render(progress=1){
  ctx.clearRect(0,0,W(),H());
  ctx.fillStyle=S.bg;ctx.fillRect(0,0,W(),H());

  if(!S.letters.length){
    ctx.fillStyle='#333';ctx.font='14px sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText('Enter an intention and click Generate',CX(),CY());
    return;
  }

  const R=Math.min(W(),H())*0.43*S.gscale;
  const gridData=getGridPoints(S.grid,S.letters,R,CX(),CY(),S.seed,S.rotate);

  // Draw overlay behind everything
  if(S.overlay)drawOverlay(S.overlayStyle,R*1.08,S.overlayOp);

  // Draw grid
  drawGrid(gridData,R,progress>=1);

  // Get path points
  const pathPts=S.letters.map(ch=>getLetterPoint(ch,gridData)).filter(Boolean);

  // Draw sigil path
  if(pathPts.length>=2)drawSigilPath(pathPts,progress);

  // Draw path dots on top
  if(progress>=1)drawPathDots(pathPts);
}

// ── Generate ──
function generate(){
  const intent=document.getElementById('tIntention').value.trim();
  if(!intent)return;
  S.intention=intent;
  S.reduction=document.getElementById('tReduction').value;
  S.letters=processIntention(intent,S.reduction);

  // Update displays
  document.getElementById('letterDisplay').textContent=S.letters.join(' ')||'(no letters)';
  document.getElementById('intentionDisplay').textContent=`"${intent}" → ${S.letters.length} letters`;

  // Step list
  const stepEl=document.getElementById('stepList');
  if(S.letters.length<2){stepEl.textContent='Need at least 2 letters.';render();return;}
  stepEl.innerHTML=S.letters.map((l,i)=>`${i+1}. <span>${l}</span>`).join('<br>');

  // Interpretation box
  const interps={A:'new beginnings',B:'balance',C:'creativity',D:'determination',E:'energy',F:'focus',G:'growth',H:'harmony',I:'intuition',J:'justice',K:'knowledge',L:'love',M:'manifestation',N:'nurturing',O:'openness',P:'protection',Q:'quest',R:'resilience',S:'strength',T:'transformation',U:'unity',V:'vision',W:'wisdom',X:'the unknown',Y:'yearning',Z:'zeal'};
  document.getElementById('interpBox').innerHTML=S.letters.map(l=>`<b style="color:#FFD700">${l}</b> ${interps[l]||''}`).join(' · ');

  // Save to history
  const snap={intention:intent,letters:[...S.letters],reduction:S.reduction,grid:S.grid,color:S.color,gscale:S.gscale,rotate:S.rotate,seed:S.seed};
  history.unshift(snap);if(history.length>10)history.pop();
  renderHistory();

  animProgress=1;
  render(1);
}

function renderHistory(){
  const c=document.getElementById('histList');c.innerHTML='';
  history.forEach((h,i)=>{
    const d=document.createElement('div');d.className='hist-item';
    d.textContent=`${h.intention} (${h.letters.join('')})`;
    d.addEventListener('click',()=>{
      document.getElementById('tIntention').value=h.intention;
      Object.assign(S,{reduction:h.reduction,grid:h.grid,color:h.color,gscale:h.gscale,rotate:h.rotate,seed:h.seed});
      document.getElementById('tReduction').value=h.reduction;
      document.getElementById('tGrid').value=h.grid;
      document.getElementById('tRot').value=Math.round(h.rotate*180/Math.PI);
      document.getElementById('vRot').textContent=Math.round(h.rotate*180/Math.PI)+'°';
      generate();
    });
    c.appendChild(d);
  });
}

// ── Trace animation ──
function startTrace(){
  if(animating){cancelAnimationFrame(animId);animating=false;document.getElementById('bAnimate').textContent='Trace ▶';render(1);return;}
  if(!S.letters.length){generate();return;}
  animating=true;document.getElementById('bAnimate').textContent='Stop ⏹';
  let start=null;const duration=2000+S.letters.length*120;
  function step(ts){
    if(!start)start=ts;
    const p=Math.min((ts-start)/duration,1);
    render(p);
    if(p<1){animId=requestAnimationFrame(step);}
    else{animating=false;document.getElementById('bAnimate').textContent='Trace ▶';}
  }
  animId=requestAnimationFrame(step);
}

