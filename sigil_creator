}

let gifWorking=false;
function exportGIF(){
  if(gifWorking||!S.letters.length)return;
  gifWorking=true;
  const st=document.getElementById('status');
  const FRAMES=parseInt(document.getElementById('eFrames').value)||60;
  const FPS=20,DELAY=Math.round(1000/FPS),SZ=Math.min(getQualitySize(),480);
  const off=document.createElement('canvas');off.width=off.height=SZ;
  const oc=off.getContext('2d',{willReadFrequently:true});
  const frames=[];let frame=0;
  // GIF: trace the sigil from 0 to 1, then hold
  const holdFrames=Math.floor(FRAMES*0.2);
  const traceFrames=FRAMES-holdFrames;
  function cap(){
    if(frame>=FRAMES){
      st.textContent='Encoding…';
      setTimeout(()=>{
        try{
          const gif=GIFEncoder.encode(frames,SZ,SZ);
          const blob=new Blob([gif],{type:'image/gif'});
          const url=URL.createObjectURL(blob);
          const a=document.createElement('a');a.download='sigil_'+S.intention.slice(0,12)+'.gif';a.href=url;a.click();
          setTimeout(()=>URL.revokeObjectURL(url),3000);
          st.textContent='Saved!';setTimeout(()=>st.textContent='',3000);
        }catch(e){st.textContent='Error: '+e.message;}
        gifWorking=false;
      },50);return;
    }
    const p=frame<traceFrames?frame/traceFrames:1;
    render(p);
    oc.clearRect(0,0,SZ,SZ);oc.drawImage(CV,0,0,SZ,SZ);
    frames.push({pixels:oc.getImageData(0,0,SZ,SZ).data,delay:DELAY});
    frame++;st.textContent='Frame '+frame+'/'+FRAMES;
    setTimeout(cap,0);
  }
  st.textContent='Starting…';setTimeout(cap,10);
}

// ── Wiring ──
document.getElementById('bGenerate').addEventListener('click',generate);
document.getElementById('bAnimate').addEventListener('click',startTrace);
document.getElementById('bRandom').addEventListener('click',randomSigil);
document.getElementById('bPNG').addEventListener('click',exportPNG);
document.getElementById('bGIF').addEventListener('click',exportGIF);
document.getElementById('bOverlay').addEventListener('click',()=>{
  S.overlay=!S.overlay;
  document.getElementById('bOverlay').classList.toggle('on',S.overlay);
  render();
});
document.getElementById('tIntention').addEventListener('keydown',e=>{if(e.key==='Enter')generate();});

// Toolbar sliders
const sliders=[
  ['tLW','lw','vLW',v=>(v/10).toFixed(1),v=>S.lw=v/10],
  ['tGlow','glow','vGlow',null,v=>S.glow=v],
  ['tSmooth','smooth','vSmooth',v=>v+'%',v=>S.smooth=v/100],
  ['tGScale','gscale','vGScale',null,v=>S.gscale=v/100],
  ['tRot','rotate','vRot',v=>v+'°',v=>S.rotate=v*Math.PI/180],
  ['tSeed','seed','vSeed',null,v=>S.seed=v],
];
sliders.forEach(([id,,valId,fmt,setter])=>{
  document.getElementById(id).addEventListener('input',()=>{
    const v=+document.getElementById(id).value;
    setter(v);
    if(valId)document.getElementById(valId).textContent=fmt?fmt(v):v;
    render();
  });
});

['tGrid','tLineStyle','tTerminal','tReduction','tOverlayStyle'].forEach(id=>{
  document.getElementById(id).addEventListener('change',e=>{
    S[{tGrid:'grid',tLineStyle:'lineStyle',tTerminal:'terminal',tReduction:'reduction',tOverlayStyle:'overlayStyle'}[id]]=e.target.value;
    if(id==='tReduction'){S.letters=processIntention(S.intention,S.reduction);document.getElementById('letterDisplay').textContent=S.letters.join(' ');}
    render();
  });
});

document.getElementById('tOverlayOp').addEventListener('input',()=>{S.overlayOp=+document.getElementById('tOverlayOp').value/100;document.getElementById('vOverlayOp').textContent=document.getElementById('tOverlayOp').value+'%';render();});
document.getElementById('tOpacity').addEventListener('input',()=>{S.opacity=+document.getElementById('tOpacity').value/100;document.getElementById('vOpacity').textContent=document.getElementById('tOpacity').value+'%';render();});
document.getElementById('tSigilW').addEventListener('input',()=>{S.sigilWeight=+document.getElementById('tSigilW').value/100;document.getElementById('vSigilW').textContent=document.getElementById('tSigilW').value+'%';render();});

// Layers
['lCircle:circle','lGrid:grid','lLabels:labels','lDoubleRing:doubleRing','lTicks:ticks','lShadow:shadow'].forEach(pair=>{
  const[id,key]=pair.split(':');
  document.getElementById(id).addEventListener('change',e=>{S.layers[key]=e.target.checked;render();});
});

// Colour swatches
function buildSwatch(containerId,colMap,onClick){
  const c=document.getElementById(containerId);
  Object.entries(colMap).forEach(([k,hex])=>{
    const s=document.createElement('div');s.className='sw';s.style.background=hex;s.dataset.ck=k;s.title=k;
    s.addEventListener('click',()=>{c.querySelectorAll('.sw').forEach(x=>x.classList.remove('sel'));s.classList.add('sel');onClick(k,hex);});
    c.appendChild(s);
  });
}
buildSwatch('swColor',COLS,(k,hex)=>{S.color=hex;S.glow2=GLOWS[k];document.getElementById('customColor').value=hex;render();});
document.querySelector('#swColor .sw').classList.add('sel');
buildSwatch('swBg',BGS,(k,hex)=>{S.bg=hex;document.getElementById('customBg').value=hex;render();});
document.querySelector('#swBg .sw').classList.add('sel');
document.getElementById('customColor').addEventListener('input',e=>{S.color=e.target.value;S.glow2=e.target.value+'88';document.querySelectorAll('#swColor .sw').forEach(x=>x.classList.remove('sel'));render();});
document.getElementById('customBg').addEventListener('input',e=>{S.bg=e.target.value;render();});

// Init
resize();
generate();
</script>
